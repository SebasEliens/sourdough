# Optional: when set, the API uses PostgreSQL (e.g. local or Docker). Takes precedence over Supabase.
# DATABASE_URL=postgresql://user:password@localhost:5432/sourdough

# Optional: when set (and DATABASE_URL unset), the API uses Supabase instead of in-memory store.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for DELETE /messages (admin). Set in production.
# ADMIN_SECRET=your-secret
